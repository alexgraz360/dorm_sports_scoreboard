# Dorm Wire — environment variables (NAMES only; never commit real values).
# Copy to .env (gitignored) and fill in. Anything left blank falls back to
# sample data so the boards still render. ESPN, MLB statsapi, Sleeper, and
# Open-Meteo weather need NO key.

# --- Fantasy (Sleeper; config, not secret) ---
SLEEPER_USERNAME_ALEX=
SLEEPER_USERNAME_JORDAN=

# --- Fantasy (ESPN private leagues only; SECRET browser cookies) ---
ESPN_S2=
ESPN_SWID=
# ESPN league IDs (from the league URL ?leagueId=...). Comma-separated. Not secret.
ESPN_LEAGUE_IDS=

# --- Markets ---
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# --- Schedules (Google Calendar private iCal URLs; SECRET) ---
GOOGLE_ICAL_URL_ALEX=
GOOGLE_ICAL_URL_JORDAN=
